# =============================================
# XAUUSD Signal Bot — Environment Variables
# =============================================

# REQUIRED: Your Telegram Bot Token
# Get it from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# OPTIONAL: Twelve Data API Key for live prices
# Free tier at https://twelvedata.com (800 requests/day)
# If left blank, bot uses realistic market simulation
TWELVE_DATA_KEY=your_twelve_data_key_here
